floating_modifier Mod4 normal

bindsym Mod4+Shift+q kill
bindsym Mod4+d       exec rofi -show combi -combi-modes "window,drun" -modes combi
bindsym Mod4+Shift+c reload
bindsym Mod4+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -B 'Yes, exit sway' 'swaymsg exit'
bindsym Mod4+Return  exec foot

bindsym Mod4+h focus left
bindsym Mod4+j focus down
bindsym Mod4+k focus up
bindsym Mod4+l focus right

bindsym Mod4+Shift+h move left
bindsym Mod4+Shift+j move down
bindsym Mod4+Shift+k move up
bindsym Mod4+Shift+l move right

bindsym Mod4+1 workspace number 1
bindsym Mod4+2 workspace number 2
bindsym Mod4+3 workspace number 3
bindsym Mod4+4 workspace number 4
bindsym Mod4+5 workspace number 5
bindsym Mod4+6 workspace number 6
bindsym Mod4+7 workspace number 7
bindsym Mod4+8 workspace number 8
bindsym Mod4+9 workspace number 9
bindsym Mod4+0 workspace number 10

bindsym Mod4+Shift+1 move container to workspace number 1;  workspace number 1
bindsym Mod4+Shift+2 move container to workspace number 2;  workspace number 2
bindsym Mod4+Shift+3 move container to workspace number 3;  workspace number 3
bindsym Mod4+Shift+4 move container to workspace number 4;  workspace number 4
bindsym Mod4+Shift+5 move container to workspace number 5;  workspace number 5
bindsym Mod4+Shift+6 move container to workspace number 6;  workspace number 6
bindsym Mod4+Shift+7 move container to workspace number 7;  workspace number 7
bindsym Mod4+Shift+8 move container to workspace number 8;  workspace number 8
bindsym Mod4+Shift+9 move container to workspace number 9;  workspace number 9
bindsym Mod4+Shift+0 move container to workspace number 10; workspace number 10

bindsym Mod4+b splith
bindsym Mod4+v splitv

bindsym Mod4+s layout stacking
bindsym Mod4+w layout tabbed
bindsym Mod4+e layout toggle split

bindsym Mod4+f           fullscreen
bindsym Mod4+Shift+space floating toggle
bindsym Mod4+space       focus mode_toggle
bindsym Mod4+a           focus parent

bindsym Mod4+Shift+minus move scratchpad
bindsym Mod4+minus       scratchpad show

mode "resize" {
    bindsym h resize shrink width  10px
    bindsym j resize grow   height 10px
    bindsym k resize shrink height 10px
    bindsym l resize grow   width  10px

    bindsym Return mode "default"
    bindsym Escape mode "default"
}

bindsym Mod4+r mode "resize"

bindsym --locked XF86AudioMute        exec pactl set-sink-mute   \@DEFAULT_SINK@   toggle
bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume \@DEFAULT_SINK@   -5%
bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume \@DEFAULT_SINK@   +5%
bindsym --locked XF86AudioMicMute     exec pactl set-source-mute \@DEFAULT_SOURCE@ toggle

bindsym Print exec grim -g "$(slurp)" - | wl-copy
bindsym Shift+Print exec grim - | wl-copy

output * bg ~/.dotfiles/wallpaper.jpg fill

include /etc/sway/config.d/*

default_border normal 1
default_floating_border normal 1

titlebar_padding 2
title_align center

set $text          #FFFFFF
set $unfocused     #00000080
set $focused       #906090
set $focused_trans #90609080
set $alert         #A00000
set $indicator     #FFCCFF

client.focused          $focused   $focused_trans $text $indicator $focused
client.unfocused        $focused   $unfocused     $text $indicator $focused
client.focused_inactive $focused   $unfocused     $text $indicator $focused
client.urgent           $alert     $alert         $text $indicator $alert

output DP-2 mode 1920x1080@144hz

input type:keyboard xkb_layout gb
input type:keyboard repeat_delay 200
input type:keyboard repeat_rate 40

input type:pointer accel_profile "flat"

focus_on_window_activation focus

exec gsettings set org.gnome.desktop.interface gtk-theme HighContrastInverse
exec gsettings set org.gnome.desktop.interface icon-theme HighContrastInverse
exec gsettings set org.gnome.desktop.interface color-scheme prefer-dark

for_window [app_id=thunar]      floating enable
for_window [app_id=pavucontrol] floating enable
for_window [class=steam_app_.*] floating enable

for_window [class=steam_app_.*] move container to workspace number 1
for_window [class=Aseprite]     move container to workspace number 1

for_window [class=steam]        move container to workspace number 2

for_window [app_id=firefox]     move container to workspace number 3

for_window [class=discord]      move container to workspace number 4

bar {
    swaybar_command waybar
}

exec dunst

output * adaptive_sync on

# ABS_X = 21600
# ABS_Y = 13500
# ABS_Z = 0
input 1386:891:Wacom_One_by_Wacom_M_Pen left_handed enable
