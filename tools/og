#!/bin/bash

open_in_editor() {
    file=$1
    line=$2
    col=$(($3 - 1))
    if [[ $line = "" ]]
    then
        $EDITOR $file
        exit 0
    elif [[ $(($col < 1)) = "1" ]]
    then
        $EDITOR $1 +$2
        exit 0
    fi
    $EDITOR $file +$line -e "exec $col\l"
}

input=$1

if [[ $input = "" ]]
then
    read input
fi

if [[ $input = "" ]]
then
    echo "no input provided"
    exit 1
fi
open_in_editor $(echo "$input" | awk -F: '{print $1, $2, $3}')
